ght = (props) => {\r\n  return (\r\n    <div id={props.id} className=\"hoja__spotlight\">\r\n      <img src={Lightbulb} />\r\n      <div className=\"hoja__spotlight-container\">\r\n        <h2>Reflektera</h2>\r\n        <ul>\r\n        {props.list.map((listItem, index) =>\r\n            <li key={index}><p>{listItem}</p></li>\r\n        )}\r\n        </ul>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default Spotlight","C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\components\\intro\\Intro.js",["169"],[],"import React from 'react';\r\nimport { Video } from '..';\r\nimport './intro.css';\r\n\r\nconst Intro = (props) => {\r\n  return (\r\n    <div id={props.id} className=\"hoja__intro\">\r\n        <div className=\"hoja__intro-container\">\r\n            <h1>{props.subtitle}</h1>\r\n            {props.paragraphs.map((paragraph, index) =>\r\n                <p key={index}>{paragraph}</p>\r\n            )}\r\n        </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default Intro","C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\components\\navbar\\Navbar.jsx",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\components\\header\\Header.jsx",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\Modul1.js",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\footer\\Footer.jsx",["170"],[],"import React from 'react';\r\nimport { Link } from 'react-router-dom';\r\nimport './footer.css';\r\nimport gpt3Logo from '../../assets/logo.png';\r\n\r\nconst Footer = () => {\r\n  return (\r\n    <div className=\"gpt3__footer section__padding\">\r\n        <div className=\"gpt3__footer-links\">\r\n          <div className=\"gpt3__footer-links_div\">\r\n            <h4>Länkar</h4>\r\n            <p>exempel</p>\r\n            <p>exempel</p>\r\n            <p>exempel</p>\r\n            <p>exempel</p>\r\n          </div>\r\n          <div className=\"gpt3__footer-links_div\">\r\n            <h4>Meny</h4>\r\n            <p>Terms & Conditions</p>\r\n            <p>Privacy Policy</p>\r\n            <p>exempel</p>\r\n          </div>\r\n          <div className=\"gpt3__footer-links_div\">\r\n            <h4>Kontakt</h4>\r\n            <p>exempel</p>\r\n            <p>exempel</p>\r\n            <p>exempel</p>\r\n            <p>exempel</p>\r\n          </div>\r\n        </div>\r\n\r\n        <div className=\"gpt3__footer-copyright\">\r\n            <img src={gpt3Logo} alt=\"logo\" />\r\n            <p>exempel</p>\r\n        </div>\r\n    </div>\r\n  )\r\n}\r\n\r\nexport default Footer","C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\Values.js",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\index.js",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\ONE\\One.js",["171"],[],"import React from 'react';\r\nimport { Story, Video, ListBox, Spotlight } from '../../../../components';\r\nimport Values from './Values';\r\nimport './one.css';\r\n\r\nconst One = (props) => {\r\n  return (\r\n    <div id='modul1__one' className='hoja__one'>\r\n      <h1>{Values.title}</h1>\r\n        <div className='hoja__columns'>\r\n          <div className='hoja__one-text'>\r\n            {Values.paragraphs.map((paragraph, index) =>\r\n                <p key={index}>{paragraph}</p>\r\n            )}\r\n          </div>\r\n          <div>\r\n            <Video video={Values.video} />\r\n          </div>\r\n        </div>\r\n        <ListBox title={Values.tips.title} list={Values.tips.list} summary={Values.tips.summary} />\r\n        <Spotlight list={Values.reflect} />\r\n      </div>\r\n  )\r\n}\r\nexport default One","C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\TWO\\Two.js",["172"],[],"import React from 'react';\r\nimport { Story, Video, Spotlight } from '../../../../components';\r\nimport Values from './Values';\r\nimport './two.css';\r\n\r\nconst Two = (props) => {\r\n  return (\r\n    <div id='modul1__two' className='hoja__two'>\r\n      <h1>{Values.title}</h1>\r\n        <div className='hoja__columns'>\r\n          <div>\r\n            <Video video={Values.video} />\r\n            <h2>{Values.subtitle}</h2>\r\n            {Values.paragraphs.map((paragraph, index) =>\r\n                  <p key={index}>{paragraph}</p>\r\n              )}\r\n            <ol>\r\n              {Values.list1.map((listItem, index) =>\r\n                  <li key={index}><p>{listItem}</p></li>\r\n              )}\r\n            </ol>\r\n          </div>\r\n          <div>\r\n            <ol>\r\n              {Values.list2.map((listItem, index) =>\r\n                  <li key={index}><p>{listItem}</p></li>\r\n              )}\r\n            </ol>\r\n            <p className='hoja__two-ref'>{Values.ref}</p>\r\n          </div>\r\n        </div>\r\n        <Spotlight list={Values.reflect} />\r\n      </div>\r\n  )\r\n}\r\nexport default Two","C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\FIVE\\Five.js",["173"],[],"import React from 'react';\r\nimport { Spotlight, Story, Video } from '../../../../components';\r\nimport Values from './Values';\r\nimport './five.css';\r\n\r\nconst Five = (props) => {\r\n  return (\r\n    <div id='modul1__five' className='hoja__five'>\r\n      <h1>{Values.title}</h1>\r\n        <div className='hoja__columns'>\r\n          <div>\r\n            {Values.paragraphs.map((paragraph, index) =>\r\n                <p key={index}>{paragraph}</p>\r\n            )}\r\n          </div>\r\n          <div>\r\n            <Video video={Values.video} />\r\n          </div>\r\n        </div>\r\n        <Spotlight list={Values.reflect} />\r\n    </div>\r\n  )\r\n}\r\nexport default Five","C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\FOUR\\Four.js",["174"],[],"import React from 'react';\r\nimport { Spotlight, Story, Video } from '../../../../components';\r\nimport Values from './Values';\r\nimport './four.css';\r\n\r\nconst Four = (props) => {\r\n  return (\r\n    <div id='modul1__four' className='hoja__four'>\r\n      <h1>{Values.title}</h1>\r\n        <div className='hoja__columns'>\r\n          <div>\r\n            {Values.paragraphs.map((paragraph, index) =>\r\n                <p key={index}>{paragraph}</p>\r\n            )}\r\n          </div>\r\n          <div>\r\n            <Video video={Values.video} />\r\n          </div>\r\n        </div>\r\n        <Spotlight list={Values.reflect} />\r\n    </div>\r\n  )\r\n}\r\nexport default Four","C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\THREE\\Three.js",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\SIX\\Six.js",["175","176"],[],"import React from 'react';\r\nimport { Spotlight, Story, Video } from '../../../../components';\r\nimport Values from './Values';\r\nimport './six.css';\r\n\r\nconst Six = (props) => {\r\n  return (\r\n    <div id='modul1__six' className='hoja__six'>\r\n      <h1>{Values.title}</h1>\r\n      <div className='hoja__columns'>\r\n          <div>\r\n              <Video video={Values.video} />\r\n          </div>\r\n          <div>\r\n              <p>{Values.text}</p>\r\n          </div>\r\n      </div>\r\n    </div>\r\n  )\r\n}\r\nexport default Six","C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\ONE\\Values.js",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\TWO\\Values.js",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\FIVE\\Values.js",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\FOUR\\Values.js",["177"],[],"import React from \"react\";\r\n\r\nconst Values = {\r\n    title: 'När man känner att ingen lyssnar',\r\n    paragraphs: [\r\n        'Gulderen försökte hitta stöd och hjälp hos hennes församling, men kände inte att hon blev lyssnad på. Hon upplevde att det fanns en rädsla för att prata om våldet och det som hände i hennes relation.',\r\n    ],\r\n    video: {\r\n        title: 'När man känner att ingen lyssnar',\r\n        link: 'https://www.youtube-nocookie.com/embed/3ark5uRvXr4'\r\n    },\r\n    reflect: [\r\n        'Varför tror du att det kan vara svårt att prata om våld i nära relation?',\r\n    ],\r\n}\r\nexport default Values;","C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\THREE\\Values.js",[],[],"C:\\Users\\alias\\Documents\\Projekt\\hoja\\src\\containers\\modul1\\delar\\SIX\\Values.js",["178"],[],"import React from \"react\";\r\n\r\nconst Values = {\r\n    title: 'Möta motståndet och våga jobba med frågan',\r\n    video: {\r\n        title: 'Vad skulle man kunna göra',\r\n        link: 'https://www.youtube-nocookie.com/embed/XbyBp5oBFbA'\r\n    },\r\n    text: 'När en kvinna samlar kraft och berättar om sin situation är det viktigt att bemöta det, att kvinnan inte möts av motstånd. Gulderen pratar om församlingarnas roll att kunna möta dessa typer av frågor. Hon ser att det är viktigt att prata om relationer i ett tidigt stadie. Relationer kan vara svåra, därför kan vara viktigt att ha ett samtal med någon som kan vägleda båda personerna i relationen.',\r\n}\r\nexport default Values;",{"ruleId":"179","severity":1,"message":"180","line":8,"column":7,"nodeType":"181","endLine":8,"endColumn":30},{"ruleId":"182","severity":1,"message":"183","line":2,"column":10,"nodeType":"184","messageId":"185","endLine":2,"endColumn":15},{"ruleId":"182","severity":1,"message":"186","line":2,"column":10,"nodeType":"184","messageId":"185","endLine":2,"endColumn":14},{"ruleId":"182","severity":1,"message":"187","line":2,"column":10,"nodeType":"184","messageId":"185","endLine":2,"endColumn":15},{"ruleId":"182","severity":1,"message":"187","line":2,"column":10,"nodeType":"184","messageId":"185","endLine":2,"endColumn":15},{"ruleId":"182","severity":1,"message":"187","line":2,"column":21,"nodeType":"184","messageId":"185","endLine":2,"endColumn